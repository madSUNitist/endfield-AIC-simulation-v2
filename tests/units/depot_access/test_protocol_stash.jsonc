{
    "protocol_stash": {
        "name": "Protocol Stash Basic",
        "ticks": 30,
        "inventory": { "ore": 9999 },
        "components": [
            { "pos": [ 0, -1], "type": "depot_loader",    "rot": "ROT_0", "item": "ore" },
            { "pos": [ 1,  0], "type": "protocol_stash",   "rot": "ROT_0" },
            { "path": [[1,3],[1,4]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [ 1,  5], "type": "depot_unloader",   "rot": "ROT_0" }
        ]
    },
    "protocol_stash_two_inputs": {
        "name": "Protocol Stash Two Inputs",
        "ticks": 400,
        "inventory": { "ore": 9999, "copper": 9999 },
        "components": [
            { "pos": [-1, -1], "type": "depot_loader",  "rot": "ROT_0", "item": "ore" },
            { "type": "conveyor", "path": [[0,0],[2,0],[2,1]], "direction_in": "up", "direction_out": "down" },
            { "pos": [ 3, -1], "type": "depot_loader",  "rot": "ROT_0", "item": "copper" },
            { "type": "conveyor", "path": [[4,0],[4,1]], "direction_in": "up", "direction_out": "down" },
            { "pos": [ 2,  2], "type": "protocol_stash", "rot": "ROT_0" },
            { "path": [[2,5],[2,6]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [ 1,  7], "type": "depot_unloader",  "rot": "ROT_0" }
        ]
    },
    "stash_basic_flow": {
        "name": "Stash Basic Flow",
        "mode": "integration",
        "ticks": 11,
        "inventory": { "ore": 9999 },
        "components": [
            { "pos": [ 0, -1], "type": "depot_loader",    "rot": "ROT_0", "item": "ore" },
            { "pos": [ 1,  0], "type": "protocol_stash",   "rot": "ROT_0" },
            { "path": [[1,3],[1,4]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [ 1,  5], "type": "depot_unloader",   "rot": "ROT_0" }
        ],
        "assertions": [
            { "target": "components[type=LOGISTICS_BELT_CONVEYOR][0]._count", "op": ">", "value": 0 },
            { "target": "inventory.ore", "op": "<", "value": 9999 }
        ]
    },
    "stash_can_pull": {
        "name": "Stash Can Pull After Tick",
        "mode": "integration",
        "ticks": 1,
        "inventory": { "ore": 9999 },
        "components": [
            { "pos": [ 0, -1], "type": "depot_loader",    "rot": "ROT_0", "item": "ore" },
            { "pos": [ 1,  0], "type": "protocol_stash",   "rot": "ROT_0" },
            { "path": [[1,3],[1,4]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [ 1,  5], "type": "depot_unloader",   "rot": "ROT_0" }
        ],
        "assertions": [
            { "target": "components[type=LOGISTICS_BELT_CONVEYOR][0]._count", "op": ">", "value": 0 }
        ]
    },
    "stash_request_upstream_all": {
        "name": "Stash Request Upstream All",
        "mode": "integration",
        "ticks": 1,
        "inventory": { "ore": 9999 },
        "components": [
            { "pos": [ 0, -1], "type": "depot_loader",    "rot": "ROT_0", "item": "ore" },
            { "pos": [ 1,  0], "type": "protocol_stash",   "rot": "ROT_0" },
            { "path": [[1,3],[1,4]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [ 1,  5], "type": "depot_unloader",   "rot": "ROT_0" }
        ],
        "assertions": [
            { "target": "ProtocolStash:0.upstreams.len", "op": "==", "value": 1 },
            { "target": "components[type=LOGISTICS_BELT_CONVEYOR][0]._count", "op": ">", "value": 0 },
            { "target": "ProtocolStash:0._buffer", "op": "is_none" }
        ]
    },
    "stash_two_inputs_block": {
        "name": "Stash Two Inputs Block",
        "mode": "integration",
        "ticks": 400,
        "inventory": { "ore": 9999, "copper": 9999 },
        "components": [
            { "pos": [-1, -1], "type": "depot_loader",  "rot": "ROT_0", "item": "ore" },
            { "type": "conveyor", "path": [[0,0],[2,0],[2,1]], "direction_in": "up", "direction_out": "down" },
            { "pos": [ 3, -1], "type": "depot_loader",  "rot": "ROT_0", "item": "copper" },
            { "type": "conveyor", "path": [[4,0],[4,1]], "direction_in": "up", "direction_out": "down" },
            { "pos": [ 2,  2], "type": "protocol_stash", "rot": "ROT_0" },
            { "path": [[2,5],[2,6]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [ 1,  7], "type": "depot_unloader",  "rot": "ROT_0" }
        ],
        "assertions": [
            { "target": "ProtocolStash:0._inv.count()", "op": ">", "value": 100 }
        ]
    },
    "stash_rr_123": {
        "name": "Stash RR 123",
        "mode": "unit",
        "setup": {
            "instances": [
                { "id": 0, "class": "ProtocolStash", "args": { "inventory_size": 6 } },
                { "id": 1, "class": "MockDownstream", "args": { "length": 50 } },
                { "id": 2, "class": "MockDownstream", "args": { "length": 50 } },
                { "id": 3, "class": "MockDownstream", "args": { "length": 50 } }
            ],
            "wiring": {
                "0.downstreams": [1, 2, 3],
                "0._owner_downstreams": [1, 2, 3]
            },
            "finalize": [0]
        },
        "actions": [
            { "repeat": 6, "steps": [
                { "set": "0._buffer", "item": "ore" },
                { "set": "0.pull_requests", "refs": [1, 2, 3] },
                { "call": "0.fulfill_requests" }
            ]}
        ],
        "assertions": [
            { "target": "1.received_ids", "op": "==", "value": [1, 1] },
            { "target": "2.received_ids", "op": "==", "value": [2, 2] },
            { "target": "3.received_ids", "op": "==", "value": [3, 3] }
        ]
    },
    "stash_fulfill_clears_pulls": {
        "name": "Stash Fulfill Clears Pulls",
        "mode": "hybrid",
        "ticks": 0,
        "inventory": { "ore": 9999 },
        "components": [
            { "pos": [ 0, -1], "type": "depot_loader",    "rot": "ROT_0", "item": "ore" },
            { "pos": [ 1,  0], "type": "protocol_stash",   "rot": "ROT_0" },
            { "path": [[1,3],[1,4]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [ 1,  5], "type": "depot_unloader",   "rot": "ROT_0" }
        ],
        "actions": [
            { "set": "ProtocolStash:0._buffer", "item": "ore" },
            { "call": "ProtocolStash:0.add_pull", "ref": "Conveyor:0" },
            { "call": "ProtocolStash:0.fulfill_requests" }
        ],
        "assertions": [
            { "target": "ProtocolStash:0.pull_requests.len", "op": "==", "value": 0 }
        ]
    },
    "stash_multi_fulfill": {
        "name": "Stash Multi Fulfill",
        "mode": "hybrid",
        "ticks": 0,
        "inventory": { "ore": 9999 },
        "components": [
            { "pos": [ 0, -1], "type": "depot_loader",    "rot": "ROT_0", "item": "ore" },
            { "pos": [ 1,  0], "type": "protocol_stash",   "rot": "ROT_0" },
            { "path": [[1,3],[1,4]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [ 1,  5], "type": "depot_unloader",   "rot": "ROT_0" }
        ],
        "actions": [
            { "push_inv": "ProtocolStash:0._inv", "item": "ore", "count": 3 },
            { "call": "ProtocolStash:0.add_pull", "ref": "Conveyor:0" },
            { "call": "ProtocolStash:0.add_pull", "ref": "Conveyor:0" },
            { "call": "ProtocolStash:0.add_pull", "ref": "Conveyor:0" },
            { "call": "ProtocolStash:0.fulfill_requests" }
        ],
        "assertions": [
            { "target": "ProtocolStash:0.pull_requests.len", "op": "==", "value": 0 },
            { "target": "ProtocolStash:0._inv.count()", "op": "<", "value": 3 }
        ]
    },
    "stash_accept_step1_forward": {
        "name": "Stash Accept Step 1: Forward to Conv",
        "mode": "hybrid",
        "ticks": 0,
        "inventory": { "ore": 9999 },
        "components": [
            { "pos": [ 0, -1], "type": "depot_loader",    "rot": "ROT_0", "item": "ore" },
            { "pos": [ 1,  0], "type": "protocol_stash",   "rot": "ROT_0" },
            { "path": [[1,3],[1,4]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [ 1,  5], "type": "depot_unloader",   "rot": "ROT_0" }
        ],
        "actions": [
            { "call": "ProtocolStash:0._accept_item", "item": "ore" },
            { "call": "ProtocolStash:0.phase2" }
        ],
        "assertions": [
            { "target": "Conveyor:0._slots[-1]", "op": "not_none" },
            { "target": "ProtocolStash:0._buffer", "op": "is_none" }
        ]
    },
    "stash_accept_step2_fill": {
        "name": "Stash Accept Step 2: Fill Conv",
        "mode": "hybrid",
        "ticks": 0,
        "inventory": { "ore": 9999 },
        "components": [
            { "pos": [ 0, -1], "type": "depot_loader",    "rot": "ROT_0", "item": "ore" },
            { "pos": [ 1,  0], "type": "protocol_stash",   "rot": "ROT_0" },
            { "path": [[1,3],[1,4]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [ 1,  5], "type": "depot_unloader",   "rot": "ROT_0" }
        ],
        "actions": [
            { "call": "ProtocolStash:0._accept_item", "item": "ore" },
            { "call": "ProtocolStash:0.phase2" },
            { "call": "ProtocolStash:0._accept_item", "item": "ore" },
            { "call": "ProtocolStash:0.phase2" }
        ],
        "assertions": [
            { "target": "Conveyor:0._count", "op": "==", "value": 2 }
        ]
    },
    "stash_accept_step3_buffer": {
        "name": "Stash Accept Step 3: Buffer",
        "mode": "hybrid",
        "ticks": 0,
        "inventory": { "ore": 9999 },
        "components": [
            { "pos": [ 0, -1], "type": "depot_loader",    "rot": "ROT_0", "item": "ore" },
            { "pos": [ 1,  0], "type": "protocol_stash",   "rot": "ROT_0" },
            { "path": [[1,3],[1,4]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [ 1,  5], "type": "depot_unloader",   "rot": "ROT_0" }
        ],
        "actions": [
            { "call": "ProtocolStash:0._accept_item", "item": "ore" },
            { "call": "ProtocolStash:0.phase2" },
            { "call": "ProtocolStash:0._accept_item", "item": "ore" },
            { "call": "ProtocolStash:0.phase2" },
            { "call": "ProtocolStash:0._accept_item", "item": "ore" }
        ],
        "assertions": [
            { "target": "ProtocolStash:0._buffer", "op": "not_none" }
        ]
    },
    "stash_accept_step4_inventory": {
        "name": "Stash Accept Step 4: Overflow to Inventory",
        "mode": "hybrid",
        "ticks": 0,
        "inventory": { "ore": 9999 },
        "components": [
            { "pos": [ 0, -1], "type": "depot_loader",    "rot": "ROT_0", "item": "ore" },
            { "pos": [ 1,  0], "type": "protocol_stash",   "rot": "ROT_0" },
            { "path": [[1,3],[1,4]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [ 1,  5], "type": "depot_unloader",   "rot": "ROT_0" }
        ],
        "actions": [
            { "call": "ProtocolStash:0._accept_item", "item": "ore" },
            { "call": "ProtocolStash:0.phase2" },
            { "call": "ProtocolStash:0._accept_item", "item": "ore" },
            { "call": "ProtocolStash:0.phase2" },
            { "call": "ProtocolStash:0._accept_item", "item": "ore" },
            { "call": "ProtocolStash:0._accept_item", "item": "ore" }
        ],
        "assertions": [
            { "target": "ProtocolStash:0._inv.count()", "op": "==", "value": 1 }
        ]
    }
}
