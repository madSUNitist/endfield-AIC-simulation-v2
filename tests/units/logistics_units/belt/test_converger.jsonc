{
    "converger_line": {
        "name": "Converger Line",
        "mode": "integration",
        "ticks": 60
        "inventory": { "ore": 9999 },
        "components": [
            { "pos": [-2,  1], "type": "depot_loader", "rot": "ROT_3", "item": "ore" },
            { "path": [[-1,0]], "type": "conveyor", "direction_in": "left", "direction_out": "right" },
            { "pos": [ 2, -1], "type": "depot_loader", "rot": "ROT_1", "item": "ore" },
            { "path": [[1,0]], "type": "conveyor", "direction_in": "right", "direction_out": "left" },
            { "pos": [ 0,  0], "type": "converger",     "rot": "ROT_0" },
            { "path": [[0,1],[0,4]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [-1,  5], "type": "depot_unloader","rot": "ROT_0" }
        ],
        "assertions": [
            { "target": "graph.order.len", "op": "==", "value": 7 },
            { "target": "components[type=LOGISTICS_BELT_CONVERGER].len", "op": "==", "value": 1 },
            { "target": "components[type=LOGISTICS_BELT_CONVEYOR].len", "op": "==", "value": 3 },
            { "target": "components[type=LOGISTICS_BELT_CONVEYOR].all._count", "op": ">", "value": 0, "min_matches": 1 },
            { "target": "components[type=DEPOT_ACCESS_DEPOT_UNLOADER].len", "op": "==", "value": 1 },
            { "target": "inventory.ore", "op": "<", "value": 9999 }
        ]
    },
    "converger_buffer_capacity": {
        "name": "Converger Buffer Capacity",
        "mode": "integration",
        "ticks": 100
        "inventory": { "ore": 9999 },
        "components": [
            { "pos": [-2,  1], "type": "depot_loader", "rot": "ROT_3", "item": "ore" },
            { "path": [[-1,0]], "type": "conveyor", "direction_in": "left", "direction_out": "right" },
            { "pos": [ 2, -1], "type": "depot_loader", "rot": "ROT_1", "item": "ore" },
            { "path": [[1,0]], "type": "conveyor", "direction_in": "right", "direction_out": "left" },
            { "pos": [ 0,  0], "type": "converger",     "rot": "ROT_0" },
            { "path": [[0,1],[0,4]], "type": "conveyor", "direction_in": "up", "direction_out": "down" },
            { "pos": [-1,  5], "type": "depot_unloader","rot": "ROT_0" }
        ],
        "assertions": [
            { "target": "components[type=LOGISTICS_BELT_CONVERGER].len", "op": "==", "value": 1 },
            { "target": "inventory.ore", "op": "<", "value": 9999 }
        ]
    },
    "converger_rr_cycling": {
        "name": "Converger RR Cycling",
        "mode": "unit",
        "setup": {
            "instances": [
                { "id": 0, "class": "Converger" },
                { "id": 1, "class": "MockSource" },
                { "id": 2, "class": "MockSource" }
            ],
            "wiring": {
                "0.upstreams": [1, 2]
            }
        },
        "actions": [
            { "repeat": 5, "steps": [
                { "call": "0.request_upstream" }
            ]}
        ],
        "assertions": [
            { "target": "1.pulls_received", "op": "==", "value": 1 },
            { "target": "2.pulls_received", "op": "==", "value": 1 }
        ]
    },
    "converger_falls_back_when_first_empty": {
        "name": "Converger Falls Back When First Empty",
        "mode": "unit",
        "setup": {
            "instances": [
                { "id": 0, "class": "Converger" },
                { "id": 1, "class": "MockSource" },
                { "id": 2, "class": "MockSource" }
            ],
            "wiring": {
                "0.upstreams": [1, 2]
            },
            "overrides": {
                "1.can_pull": false
            }
        },
        "actions": [
            { "call": "0.request_upstream" }
        ],
        "assertions": [
            { "target": "1.pulls_received", "op": "==", "value": 0 },
            { "target": "2.pulls_received", "op": "==", "value": 1 }
        ]
    },
    "converger_buffer_full_blocks_pull": {
        "name": "Converger Buffer Full Blocks Pull",
        "mode": "unit",
        "setup": {
            "instances": [
                { "id": 0, "class": "Converger" },
                { "id": 1, "class": "MockSource" }
            ],
            "wiring": {
                "0.upstreams": [1]
            }
        },
        "actions": [
            { "set": "0._buffer", "item": "ore" },
            { "call": "0.request_upstream" }
        ],
        "assertions": [
            { "target": "1.pulls_received", "op": "==", "value": 0 }
        ]
    }
}

