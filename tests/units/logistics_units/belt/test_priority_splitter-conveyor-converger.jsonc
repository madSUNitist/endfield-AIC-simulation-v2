            {"type": "depot_loader"  , "pos": [3 , 2], "rot": "ROT_0", "item": "A"},
            {"type": "depot_loader"  , "pos": [6 , 2], "rot": "ROT_0", "item": "B"},
            {"type": "depot_loader"  , "pos": [9 , 2], "rot": "ROT_0", "item": "C"},
            {"type": "conveyor"      , "path": [[4, 3], [4, 5], [5, 5]], "direction_in": "up", "direction_out": "right"},
            {"type": "conveyor"      , "path": [[10, 3], [10, 5], [9, 5]], "direction_in": "up", "direction_out": "left"},
            {"type": "conveyor"      , "path": [[7, 6], [7, 7]], "direction_in": "up", "direction_out": "down"},
            {"type": "depot_unloader", "pos": [6 , 8], "rot": "ROT_0"},
            // =========================
            {"type": "conveyor"      , "path": [[7, 3], [7, 4]], "direction_in": "up", "direction_out": "down"},  // u
            {"type": "splitter"      , "pos": [6 , 5], "rot": "ROT_3"},  // l
